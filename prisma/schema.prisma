generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  botanicalName String   @map("botanical_name")
  category      String
  description   String
  origin        String
  extraction    String
  aroma         String
  solubility    String
  refractiveIdx String   @map("refractive_idx")
  opticalRot    String   @map("optical_rot")
  purity        String
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  batches  Batch[]
  compounds ProductCompound[]

  @@map("products")
}

model ProductCompound {
  id         String @id @default(cuid())
  productId  String @map("product_id")
  name       String
  percentage String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_compounds")
}

model Batch {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  batchRef     String   @map("batch_ref")
  analysisDate DateTime @map("analysis_date")
  purityScore  String   @map("purity_score")
  status       String   @default("current")

  product    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  compounds  BatchCompound[]
  gcmsAnalyses GcmsAnalysis[]

  @@map("batches")
}

model BatchCompound {
  id        String @id @default(cuid())
  batchId   String @map("batch_id")
  name      String
  percentage String

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("batch_compounds")
}

model GcmsAnalysis {
  id           String   @id @default(cuid())
  batchId      String   @map("batch_id")
  oil          String
  analysisDate DateTime @map("analysis_date")

  batch    Batch               @relation(fields: [batchId], references: [id], onDelete: Cascade)
  compounds GcmsCompound[]

  @@map("gcms_analyses")
}

model GcmsCompound {
  id         String @id @default(cuid())
  analysisId String @map("analysis_id")
  compound   String
  percentage String

  analysis GcmsAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("gcms_compounds")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  quantity  String?
  message   String?
  source    String   @default("website")
  createdAt DateTime @default(now()) @map("created_at")

  items LeadItem[]

  @@map("leads")
}

model LeadItem {
  id        String @id @default(cuid())
  leadId    String @map("lead_id")
  productId String @map("product_id")
  name      String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_items")
}
